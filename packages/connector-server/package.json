{
  "name": "@aligndottech/connector-server",
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "description": "Align connector server: Express app factory, MCP handler, webhook guard, OTel setup, and test harness for building full Align connectors. Depends on @aligndottech/connector-core.",
  "repository": {
    "type": "git",
    "url": "https://github.com/aligndottech/align-connector-sdk",
    "directory": "packages/connector-server"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsc -w",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aligndottech/connector-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "undici": "^6.25.0"
  },
  "peerDependencies": {
    "supertest": "^7.1.0"
  },
  "peerDependenciesMeta": {
    "supertest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^25.8.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.2",
    "supertest": "^7.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
